---
/**
 * Hero.astro
 * ==========
 * Full-height hero section with animated gradient name, profile photo,
 * action buttons, social pills, stat bar, and scroll indicator.
 */
import { personalInfo, stats, socialLinks, publications } from '../data/portfolio';

const icons: Record<string, string> = {
  github: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  'folder-open': '<path d="M2 7.5V19a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2h-6.31a1 1 0 01-.69-.28L10.69 4.28a1 1 0 00-.69-.28H4a2 2 0 00-2 2z"/>',
  download: '<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>',
  'message-circle': '<path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>',
  'chevron-down': '<polyline points="6 9 12 15 18 9"/>',
};

function getIcon(name: string): string {
  return icons[name] || '';
}

const hasPublications = publications.length > 0;
---

<section id="hero" class="hero">
  <div class="hero__container">
    <div class="hero__content">
      <!-- Availability badge -->
      <div class="hero__badge animate-on-scroll">
        <span class="hero__badge-dot"></span>
        {personalInfo.availabilityBadge}
      </div>

      <!-- Name -->
      <h1 class="hero__name animate-on-scroll">
        {personalInfo.firstName}<br />
        <span class="hero__name-gradient">{personalInfo.lastName}</span>
      </h1>

      <!-- Title -->
      <p class="hero__title animate-on-scroll">{personalInfo.title}</p>

      <!-- Subtitle -->
      <p class="hero__subtitle animate-on-scroll">{personalInfo.subtitle}</p>

      <!-- Action buttons -->
      <div class="hero__actions animate-on-scroll">
        <a href="#projects" class="hero__btn hero__btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <Fragment set:html={getIcon('folder-open')} />
          </svg>
          View Projects
        </a>
        <button class="hero__btn hero__btn--secondary" id="resume-download-btn" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <Fragment set:html={getIcon('download')} />
          </svg>
          Download Resume
        </button>
        <a href="#contact" class="hero__btn hero__btn--outline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <Fragment set:html={getIcon('message-circle')} />
          </svg>
          Contact Me
        </a>
      </div>

      <!-- Social pills -->
      <div class="hero__socials animate-on-scroll">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="hero__social-pill">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={getIcon(link.icon)} />
            </svg>
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Profile photo -->
    <div class="hero__photo-wrap animate-on-scroll">
      <div class="hero__photo-ring">
        <img
          src={personalInfo.avatar}
          alt={`${personalInfo.firstName} ${personalInfo.lastName}`}
          class="hero__photo"
          width="280"
          height="280"
          loading="eager"
        />
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero__stats animate-on-scroll">
    {stats.map((stat) => (
      <div class="hero__stat">
        <span class="hero__stat-value gradient-text">{stat.value}</span>
        <span class="hero__stat-label">{stat.label}</span>
      </div>
    ))}
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll-indicator" aria-hidden="true">
    <div class="hero__mouse">
      <div class="hero__mouse-wheel"></div>
    </div>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero__scroll-arrow">
      <Fragment set:html={getIcon('chevron-down')} />
    </svg>
  </div>
</section>

<!-- Resume download button dispatch -->
<script is:inline>
  document.getElementById('resume-download-btn')?.addEventListener('click', function () {
    window.dispatchEvent(new CustomEvent('open-resume-export'));
  });
</script>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 24px 60px;
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero__container {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 48px;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-success);
    margin-bottom: 20px;
    width: fit-content;
  }
  .hero__badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
  }

  /* Name */
  .hero__name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .hero__name-gradient {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
    animation: gradient-shift 6s ease infinite;
  }

  /* Title & subtitle */
  .hero__title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 12px;
  }
  .hero__subtitle {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 520px;
    margin-bottom: 28px;
    line-height: 1.7;
  }

  /* Actions */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }
  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    border: none;
    font-family: var(--font-sans);
  }
  .hero__btn:hover { transform: translateY(-2px); }
  .hero__btn--primary {
    background: var(--gradient-primary);
    color: #fff;
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
  }
  .hero__btn--primary:hover { box-shadow: 0 6px 25px rgba(59, 130, 246, 0.45); }
  .hero__btn--secondary {
    background: var(--color-card);
    color: var(--color-text);
    border: 1px solid var(--color-glass-border);
  }
  .hero__btn--secondary:hover { border-color: var(--color-primary); }
  .hero__btn--outline {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-glass-border);
  }
  .hero__btn--outline:hover { border-color: var(--color-accent); }

  /* Social pills */
  .hero__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .hero__social-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: var(--color-card);
    border: 1px solid var(--color-glass-border);
    border-radius: 100px;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    transition: color 0.2s, border-color 0.2s;
  }
  .hero__social-pill:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  /* Photo */
  .hero__photo-wrap { display: flex; justify-content: center; }
  .hero__photo-ring {
    position: relative;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    padding: 6px;
    background: var(--gradient-primary);
    animation: hue-rotate 8s linear infinite;
  }
  @keyframes hue-rotate {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
  }
  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid var(--color-bg);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .hero__photo-ring:hover .hero__photo { transform: scale(1.05); }

  /* Stats */
  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 60px;
    padding: 28px 32px;
    background: var(--color-card);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius);
    backdrop-filter: blur(10px);
  }
  .hero__stat { text-align: center; }
  .hero__stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 800;
    font-family: var(--font-mono);
  }
  .hero__stat-label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Scroll indicator */
  .hero__scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-top: 40px;
    opacity: 0.5;
    animation: float-scroll 3s ease-in-out infinite;
  }
  .hero__mouse {
    width: 24px;
    height: 38px;
    border: 2px solid var(--color-text-muted);
    border-radius: 12px;
    position: relative;
  }
  .hero__mouse-wheel {
    width: 4px;
    height: 8px;
    background: var(--color-text-muted);
    border-radius: 2px;
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    animation: scroll-wheel 2s ease-in-out infinite;
  }
  .hero__scroll-arrow { color: var(--color-text-muted); }
  @keyframes scroll-wheel {
    0% { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(10px); }
  }
  @keyframes float-scroll {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .hero { padding: 100px 16px 40px; min-height: auto; }
    .hero__container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero__photo-wrap { order: -1; }
    .hero__photo-ring { width: 180px; height: 180px; }
    .hero__badge { margin-left: auto; margin-right: auto; }
    .hero__subtitle { margin-left: auto; margin-right: auto; }
    .hero__actions { justify-content: center; }
    .hero__socials { justify-content: center; }
    .hero__stats { grid-template-columns: repeat(2, 1fr); gap: 16px; padding: 20px; margin-top: 32px; }
    .hero__stat-value { font-size: 1.4rem; }
  }
</style>
