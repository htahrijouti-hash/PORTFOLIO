---
/**
 * AiAssistant.astro
 * ==================
 * Floating AI chatbot that answers questions about the portfolio owner
 * using a keyword-matching knowledge base built from the data file.
 * Entirely client-side — no external API needed.
 */
import {
  personalInfo, stats, technicalSkills, softSkills,
  education, experiences, publications, projects,
  socialLinks, certifications, navItems,
} from '../data/portfolio';

/* Build serialisable knowledge base */
const kb = {
  name: `${personalInfo.firstName} ${personalInfo.lastName}`,
  firstName: personalInfo.firstName,
  title: personalInfo.title,
  subtitle: personalInfo.subtitle,
  location: personalInfo.location,
  emails: personalInfo.emails,
  about: personalInfo.about.join(' '),
  stats: stats.map(s => `${s.label}: ${s.value}`).join(', '),
  skills: technicalSkills.map(c => `${c.title}: ${c.skills.join(', ')}`).join('; '),
  softSkills: softSkills.map(s => s.name).join(', '),
  education: education.map(e => `${e.degree} in ${e.field} at ${e.institution} (${e.period})`).join('; '),
  hasExperience: experiences.length > 0,
  experience: experiences.map(e => `${e.role} at ${e.company} (${e.period})`).join('; '),
  hasPublications: publications.length > 0,
  publications: publications.map(p => `${p.title} — ${p.journal} (${p.year})`).join('; '),
  hasCertifications: certifications.length > 0,
  projects: projects.map(p => `${p.title}: ${p.description} [${p.tags.join(', ')}]`).join('; '),
  social: socialLinks.map(l => `${l.label}: ${l.url}`).join(', '),
  sections: navItems.map(n => n.label),
};

/* Chips — only for sections that exist */
const chips: { label: string; query: string }[] = [
  { label: `Who is ${personalInfo.firstName}?`, query: 'about' },
  { label: 'Skills', query: 'skills' },
];
if (publications.length > 0) chips.push({ label: 'Publications', query: 'publications' });
if (experiences.length > 0) chips.push({ label: 'Experience', query: 'experience' });
chips.push({ label: 'Projects', query: 'projects' });
chips.push({ label: 'Education', query: 'education' });
chips.push({ label: 'Contact', query: 'contact' });
---

<div class="ai" id="ai-assistant">
  <!-- Toggle button -->
  <button class="ai__toggle" id="ai-toggle" type="button" aria-label="Open AI assistant">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 8V4H8"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4v4"/>
      <rect x="4" y="8" width="16" height="12" rx="2"/>
      <circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/>
    </svg>
    <span class="ai__pulse-ring"></span>
  </button>

  <!-- Chat panel -->
  <div class="ai__panel" id="ai-panel" aria-hidden="true">
    <!-- Header -->
    <div class="ai__header">
      <div class="ai__header-info">
        <div class="ai__avatar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 8V4H8"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4v4"/>
            <rect x="4" y="8" width="16" height="12" rx="2"/>
            <circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/>
          </svg>
        </div>
        <div>
          <span class="ai__header-name">Portfolio AI</span>
          <span class="ai__header-status"><span class="ai__status-dot"></span> Online</span>
        </div>
      </div>
      <button class="ai__close" id="ai-close" type="button" aria-label="Close AI assistant">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Messages -->
    <div class="ai__messages" id="ai-messages">
      <div class="ai__msg ai__msg--bot">
        <div class="ai__msg-avatar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 8V4H8"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4v4"/>
            <rect x="4" y="8" width="16" height="12" rx="2"/>
            <circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/>
          </svg>
        </div>
        <div class="ai__msg-bubble">Hi! 👋 I'm <strong>{personalInfo.firstName}'s</strong> portfolio assistant. Ask me anything about skills, projects, education, or contact info!</div>
      </div>
    </div>

    <!-- Quick action chips -->
    <div class="ai__chips" id="ai-chips">
      {chips.map((c) => (
        <button class="ai__chip" data-query={c.query} type="button">{c.label}</button>
      ))}
    </div>

    <!-- Input -->
    <div class="ai__input-bar">
      <input class="ai__input" id="ai-input" type="text" placeholder="Ask me anything…" autocomplete="off" />
      <button class="ai__send" id="ai-send" type="button" aria-label="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ kb: JSON.stringify(kb) }}>
(function () {
  var K = JSON.parse(kb);
  var panel = document.getElementById('ai-panel');
  var toggle = document.getElementById('ai-toggle');
  var closeBtn = document.getElementById('ai-close');
  var messages = document.getElementById('ai-messages');
  var input = document.getElementById('ai-input');
  var sendBtn = document.getElementById('ai-send');
  var chipsEl = document.getElementById('ai-chips');
  var chipsVisible = true;

  function open() { panel.classList.add('open'); panel.setAttribute('aria-hidden', 'false'); input.focus(); }
  function close() { panel.classList.remove('open'); panel.setAttribute('aria-hidden', 'true'); }
  toggle.addEventListener('click', function () { panel.classList.contains('open') ? close() : open(); });
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });

  /* Mini markdown renderer */
  function md(text) {
    return text
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
      .replace(/\n/g, '<br>');
  }

  function addMsg(text, isUser) {
    var div = document.createElement('div');
    div.className = 'ai__msg ai__msg--' + (isUser ? 'user' : 'bot');
    if (!isUser) {
      div.innerHTML =
        '<div class="ai__msg-avatar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4v4"/><rect x="4" y="8" width="16" height="12" rx="2"/><circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/></svg></div>' +
        '<div class="ai__msg-bubble">' + md(text) + '</div>';
    } else {
      div.innerHTML = '<div class="ai__msg-bubble">' + escapeHtml(text) + '</div>';
    }
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function escapeHtml(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function showTyping() {
    var div = document.createElement('div');
    div.className = 'ai__msg ai__msg--bot ai__typing';
    div.innerHTML =
      '<div class="ai__msg-avatar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4v4"/><rect x="4" y="8" width="16" height="12" rx="2"/><circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/></svg></div>' +
      '<div class="ai__msg-bubble"><span class="ai__dots"><span></span><span></span><span></span></span></div>';
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
    return div;
  }

  /* Knowledge-based response */
  function getResponse(q) {
    var ql = q.toLowerCase();

    /* Greetings */
    if (/^(hi|hello|hey|salut|bonjour|salam)/.test(ql))
      return 'Hello! 👋 How can I help you learn about **' + K.name + '**? You can ask about skills, projects, education, or contact info.';

    /* Thanks */
    if (/thank|merci|shukr/.test(ql))
      return "You're welcome! 😊 Feel free to ask anything else.";

    /* About */
    if (/who|about|tell me|présent|intro/.test(ql))
      return '**' + K.name + '** is a ' + K.title + ' based in ' + K.location + '.\n\n' + K.about.split('.').slice(0, 3).join('.') + '.';

    /* Skills - specific tech */
    if (/react|typescript|javascript|node|astro|python|java|html|css|sql|mongo|git/i.test(ql)) {
      var tech = ql.match(/react|typescript|javascript|node|astro|python|java|html|css|sql|mongo|git/i)[0];
      var found = K.skills.toLowerCase().includes(tech.toLowerCase());
      return found
        ? '✅ Yes! **' + K.name + '** has experience with **' + tech.charAt(0).toUpperCase() + tech.slice(1) + '**.\n\nHere are all skills: ' + K.skills
        : "I couldn't confirm that specific technology, but here are the skills I know of: " + K.skills;
    }

    /* Skills general */
    if (/skill|compet|tech|stack|tool/.test(ql))
      return '**Technical Skills:**\n' + K.skills + (K.softSkills ? '\n\n**Soft Skills:** ' + K.softSkills : '') + '\n\n👉 [See all skills](#skills)';

    /* Education */
    if (/educ|school|university|degree|diplom|study|studi|academic/.test(ql))
      return '🎓 **Education:**\n' + K.education + '\n\n👉 [See education section](#education)';

    /* Experience */
    if (/experience|job|work|stage|intern|employ/.test(ql))
      return K.hasExperience
        ? '💼 **Experience:**\n' + K.experience + '\n\n👉 [See experience](#experience)'
        : K.name + ' is currently focused on studies. Check out the [Projects](#projects) section for practical work!';

    /* Publications */
    if (/public|paper|research|article|journal/.test(ql))
      return K.hasPublications
        ? '📄 **Publications:**\n' + K.publications + '\n\n👉 [See publications](#publications)'
        : K.name + " hasn't published academic papers yet. Explore the [Projects](#projects) instead!";

    /* Projects */
    if (/project|portfolio|built|develop|app/.test(ql))
      return '🚀 **Projects:**\n' + K.projects + '\n\n👉 [See all projects](#projects)';

    /* Contact */
    if (/contact|email|reach|hire|mail|phone/.test(ql))
      return '📬 **Contact:**\nEmail: ' + K.emails.join(', ') + '\nLocation: ' + K.location + '\n\n' + K.social + '\n\n👉 [Go to contact form](#contact)';

    /* Social */
    if (/social|github|linkedin|twitter|link/.test(ql))
      return '🔗 **Social profiles:**\n' + K.social;

    /* Stats */
    if (/stat|number|count|how many/.test(ql))
      return '📊 **Key stats:** ' + K.stats;

    /* Navigation */
    if (/section|navigate|menu|page/.test(ql))
      return 'This portfolio has the following sections: **' + K.sections.join(', ') + '**. Click any section name in the navigation to jump there!';

    /* Help */
    if (/help|what can|que peux/.test(ql))
      return 'I can answer questions about:\n• **About** — who ' + K.firstName + ' is\n• **Skills** — technical & soft skills\n• **Education** — academic background\n• **Projects** — things built\n• **Contact** — how to reach out' + (K.hasExperience ? '\n• **Experience** — work history' : '') + (K.hasPublications ? '\n• **Publications** — research papers' : '');

    /* Fallback */
    return "I'm not sure I understood. Try asking about **skills**, **projects**, **education**, or **contact**. Or type **help** to see what I can do! 🤖";
  }

  function handleSend() {
    var q = input.value.trim();
    if (!q) return;
    addMsg(q, true);
    input.value = '';
    if (chipsVisible) { chipsEl.style.display = 'none'; chipsVisible = false; }

    var typing = showTyping();
    setTimeout(function () {
      typing.remove();
      var resp = getResponse(q);
      addMsg(resp, false);

      /* Auto-scroll to section links */
      var sectionMatch = resp.match(/#([\w-]+)\)/);
      if (sectionMatch) {
        var links = messages.querySelectorAll('a[href^="#"]');
        links.forEach(function (a) {
          a.addEventListener('click', function (e) {
            e.preventDefault();
            close();
            var target = document.querySelector(a.getAttribute('href'));
            if (target) target.scrollIntoView({ behavior: 'smooth' });
          });
        });
      }
    }, 600 + Math.random() * 400);
  }

  sendBtn.addEventListener('click', handleSend);
  input.addEventListener('keydown', function (e) { if (e.key === 'Enter') handleSend(); });

  /* Chips */
  chipsEl.querySelectorAll('.ai__chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
      input.value = chip.dataset.query;
      handleSend();
    });
  });
})();
</script>

<style>
  .ai { position: fixed; bottom: 24px; left: 24px; z-index: 950; }

  /* Toggle */
  .ai__toggle {
    position: relative;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--gradient-primary);
    border: none;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3);
    transition: transform 0.2s;
  }
  .ai__toggle:hover { transform: scale(1.08); }
  .ai__pulse-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--color-primary);
    animation: ai-pulse 2s ease-in-out infinite;
  }
  @keyframes ai-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 0; transform: scale(1.3); }
  }

  /* Panel */
  .ai__panel {
    position: absolute;
    bottom: 64px;
    left: 0;
    width: 360px;
    max-height: 520px;
    background: var(--color-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: scale(0.9) translateY(20px);
    pointer-events: none;
    transition: opacity 0.3s, transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .ai__panel.open {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  /* Header */
  .ai__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .ai__header-info { display: flex; align-items: center; gap: 10px; }
  .ai__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
  }
  .ai__header-name { display: block; font-weight: 600; font-size: 0.88rem; }
  .ai__header-status { display: flex; align-items: center; gap: 4px; font-size: 0.72rem; color: var(--color-success); }
  .ai__status-dot { width: 6px; height: 6px; background: var(--color-success); border-radius: 50%; }
  .ai__close {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 4px;
  }

  /* Messages */
  .ai__messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 200px;
    max-height: 300px;
  }
  .ai__msg { display: flex; gap: 8px; max-width: 88%; }
  .ai__msg--user { align-self: flex-end; flex-direction: row-reverse; }
  .ai__msg-avatar {
    width: 26px;
    height: 26px;
    min-width: 26px;
    border-radius: 50%;
    background: rgba(59, 130, 246, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    margin-top: 2px;
  }
  .ai__msg-bubble {
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.82rem;
    line-height: 1.6;
  }
  .ai__msg--bot .ai__msg-bubble {
    background: var(--color-bg-secondary);
    border-bottom-left-radius: 4px;
  }
  .ai__msg--user .ai__msg-bubble {
    background: var(--gradient-primary);
    color: #fff;
    border-bottom-right-radius: 4px;
  }
  .ai__msg-bubble a { color: var(--color-primary); text-decoration: underline; }
  .ai__msg--user .ai__msg-bubble a { color: #fff; }
  .ai__msg-bubble :global(strong) { font-weight: 600; }

  /* Typing dots */
  .ai__dots { display: flex; gap: 4px; padding: 4px 0; }
  .ai__dots span {
    width: 6px;
    height: 6px;
    background: var(--color-text-muted);
    border-radius: 50%;
    animation: bounce-dot 1.4s infinite;
  }
  .ai__dots span:nth-child(2) { animation-delay: 0.2s; }
  .ai__dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce-dot {
    0%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-6px); }
  }

  /* Chips */
  .ai__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 16px 12px;
  }
  .ai__chip {
    padding: 4px 12px;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 100px;
    font-size: 0.72rem;
    color: var(--color-accent);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background 0.2s;
  }
  .ai__chip:hover { background: rgba(139, 92, 246, 0.15); }

  /* Input bar */
  .ai__input-bar {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--color-border);
  }
  .ai__input {
    flex: 1;
    padding: 8px 12px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    outline: none;
  }
  .ai__input:focus { border-color: var(--color-primary); }
  .ai__send {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: var(--gradient-primary);
    border: none;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }
  .ai__send:hover { transform: scale(1.05); }

  @media (max-width: 768px) {
    .ai { bottom: 16px; left: 16px; }
    .ai__toggle { width: 44px; height: 44px; }
    .ai__panel {
      width: calc(100vw - 32px);
      left: -8px;
      bottom: 58px;
    }
  }
</style>
