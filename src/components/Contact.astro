---
/**
 * Contact.astro
 * ==============
 * Two-column layout: info cards + functional contact form (FormSubmit AJAX).
 * Toast overlay for success/error feedback.
 */
import { personalInfo, socialLinks } from '../data/portfolio';

const icons: Record<string, string> = {
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  phone: '<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>',
  'map-pin': '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
  github: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  send: '<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>',
  'check-circle': '<path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
  'alert-circle': '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>',
  'x': '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
};

function getIcon(name: string): string {
  return icons[name] || '';
}

const email = personalInfo.emails[0];
---

<section id="contact" class="section">
  <span class="section__label">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon('send')} /></svg>
    Contact
  </span>
  <h2 class="section__title">Get In Touch</h2>
  <p class="section__subtitle">Feel free to reach out for collaborations, opportunities, or just to say hello.</p>

  <div class="contact__grid">
    <!-- Info column -->
    <div class="contact__info">
      <!-- Email card -->
      <div class="contact__info-card animate-on-scroll">
        <div class="contact__info-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon('mail')} /></svg>
        </div>
        <div>
          <h4 class="contact__info-label">Email</h4>
          <a href={`mailto:${email}`} class="contact__info-value">{email}</a>
        </div>
      </div>

      {personalInfo.phone && (
        <div class="contact__info-card animate-on-scroll">
          <div class="contact__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon('phone')} /></svg>
          </div>
          <div>
            <h4 class="contact__info-label">Phone</h4>
            <span class="contact__info-value">{personalInfo.phone}</span>
          </div>
        </div>
      )}

      <!-- Location card -->
      <div class="contact__info-card animate-on-scroll">
        <div class="contact__info-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon('map-pin')} /></svg>
        </div>
        <div>
          <h4 class="contact__info-label">Location</h4>
          <span class="contact__info-value">{personalInfo.location}</span>
        </div>
      </div>

      <!-- Social links -->
      <div class="contact__socials animate-on-scroll">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="contact__social" aria-label={link.label}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={getIcon(link.icon)} />
            </svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Form column -->
    <form class="contact__form animate-on-scroll" id="contact-form" autocomplete="on">
      <!-- Honeypot -->
      <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="contact__field">
        <label class="contact__label" for="contact-name">Name</label>
        <input class="contact__input" type="text" id="contact-name" name="name" required placeholder="Your name" autocomplete="name" />
      </div>
      <div class="contact__field">
        <label class="contact__label" for="contact-email">Email</label>
        <input class="contact__input" type="email" id="contact-email" name="email" required placeholder="your@email.com" autocomplete="email" />
      </div>
      <div class="contact__field">
        <label class="contact__label" for="contact-subject">Subject</label>
        <input class="contact__input" type="text" id="contact-subject" name="_subject" required placeholder="What's this about?" />
      </div>
      <div class="contact__field">
        <label class="contact__label" for="contact-message">Message</label>
        <textarea class="contact__input contact__textarea" id="contact-message" name="message" required rows="5" placeholder="Write your message…"></textarea>
      </div>

      <button type="submit" class="contact__submit" id="contact-submit">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon('send')} /></svg>
        <span class="contact__submit-text">Send Message</span>
      </button>
    </form>
  </div>

  <!-- Toast overlay -->
  <div class="toast-overlay" id="toast-overlay" aria-hidden="true">
    <div class="toast-backdrop" id="toast-backdrop"></div>
    <div class="toast-card" id="toast-card">
      <button class="toast-close" id="toast-close" type="button" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><Fragment set:html={getIcon('x')} /></svg>
      </button>
      <div class="toast-icon" id="toast-icon"></div>
      <p class="toast-message" id="toast-message"></p>
      <button class="toast-btn" id="toast-btn" type="button">OK</button>
    </div>
  </div>
</section>

<script is:inline define:vars={{ email }}>
(function () {
  var form = document.getElementById('contact-form');
  var btn = document.getElementById('contact-submit');
  var overlay = document.getElementById('toast-overlay');
  var toastBackdrop = document.getElementById('toast-backdrop');
  var toastClose = document.getElementById('toast-close');
  var toastBtn = document.getElementById('toast-btn');
  var toastIcon = document.getElementById('toast-icon');
  var toastMsg = document.getElementById('toast-message');

  var successSVG = '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>';
  var errorSVG = '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';

  function showToast(success, message) {
    toastIcon.innerHTML = success ? successSVG : errorSVG;
    toastMsg.textContent = message;
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
  }
  function hideToast() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
  }

  toastBackdrop.addEventListener('click', hideToast);
  toastClose.addEventListener('click', hideToast);
  toastBtn.addEventListener('click', hideToast);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.classList.contains('open')) hideToast();
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var fd = new FormData(form);
    var body = {};
    fd.forEach(function (v, k) { body[k] = v; });

    btn.disabled = true;
    btn.querySelector('.contact__submit-text').textContent = 'Sending…';
    btn.classList.add('loading');

    fetch('https://formsubmit.co/ajax/' + email, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify(body),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) {
          showToast(true, 'Message sent successfully! I\'ll get back to you soon.');
          form.reset();
        } else {
          showToast(false, 'Something went wrong. Please try again later.');
        }
      })
      .catch(function () {
        showToast(false, 'Network error. Please check your connection and try again.');
      })
      .finally(function () {
        btn.disabled = false;
        btn.querySelector('.contact__submit-text').textContent = 'Send Message';
        btn.classList.remove('loading');
      });
  });
})();
</script>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 32px;
  }

  /* Info cards */
  .contact__info { display: flex; flex-direction: column; gap: 16px; }
  .contact__info-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: var(--color-card);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .contact__info-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .contact__info-icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.15);
    border-radius: var(--radius-sm);
    color: var(--color-primary);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .contact__info-card:hover .contact__info-icon {
    transform: scale(1.1);
    box-shadow: 0 0 16px rgba(59, 130, 246, 0.2);
  }
  .contact__info-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }
  .contact__info-value {
    font-size: 0.9rem;
    color: var(--color-text);
  }
  a.contact__info-value:hover { color: var(--color-primary); }

  /* Socials */
  .contact__socials {
    display: flex;
    gap: 10px;
    margin-top: 8px;
  }
  .contact__social {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-card);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    transition: transform 0.3s, color 0.2s, box-shadow 0.3s;
  }
  .contact__social:hover {
    transform: translateY(-3px);
    color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  /* Form */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 28px;
    background: var(--color-card);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius);
    backdrop-filter: blur(10px);
  }
  .contact__field { display: flex; flex-direction: column; gap: 6px; }
  .contact__label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .contact__input {
    padding: 10px 14px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }
  .contact__input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
  .contact__input::placeholder { color: var(--color-text-muted); opacity: 0.5; }
  .contact__textarea { resize: vertical; min-height: 100px; }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 28px;
    background: var(--gradient-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .contact__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(59, 130, 246, 0.35);
  }
  .contact__submit.loading {
    pointer-events: none;
    opacity: 0.8;
  }
  .contact__submit.loading::after {
    content: '';
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-left: 8px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Toast */
  .toast-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .toast-overlay.open {
    pointer-events: auto;
    opacity: 1;
  }
  .toast-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  .toast-card {
    position: relative;
    padding: 36px 32px;
    background: var(--color-glass);
    backdrop-filter: blur(20px);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-lg);
    text-align: center;
    max-width: 380px;
    width: 90%;
    transform: scale(0.9) translateY(20px);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .toast-overlay.open .toast-card { transform: scale(1) translateY(0); }
  .toast-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
  }
  .toast-icon { margin-bottom: 16px; }
  .toast-icon svg { display: inline-block; }
  .toast-message { font-size: 0.95rem; color: var(--color-text); margin-bottom: 20px; }
  .toast-btn {
    padding: 8px 32px;
    background: var(--gradient-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .toast-btn:hover { transform: translateY(-1px); }

  :global(html[data-theme='light']) .contact__info-icon {
    background: rgba(37, 99, 235, 0.08);
    border-color: rgba(37, 99, 235, 0.12);
  }

  @media (max-width: 768px) {
    .contact__grid { grid-template-columns: 1fr; }
    .contact__form { padding: 20px; }
  }
</style>
