---
/**
 * Projects.astro
 * ===============
 * Grid of project cards with decorative numbering, tags, and hover effects.
 */
import { projects } from '../data/portfolio';

const icons: Record<string, string> = {
  'external-link': '<path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>',
  'arrow-right': '<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>',
};
---

<section id="projects" class="section">
  <span class="section__label">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7.5V19a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2h-6.31a1 1 0 01-.69-.28L10.69 4.28a1 1 0 00-.69-.28H4a2 2 0 00-2 2z"/></svg>
    Projects
  </span>
  <h2 class="section__title">Featured Projects</h2>
  <p class="section__subtitle">A selection of projects I've built and contributed to.</p>

  <div class="projects__grid stagger-children">
    {projects.map((project, i) => (
      <div class="projects__card animate-on-scroll">
        <!-- Gradient top bar -->
        <div class="projects__bar"></div>

        <!-- Decorative number -->
        <span class="projects__number gradient-text">{String(i + 1).padStart(2, '0')}</span>

        <!-- Title -->
        <h3 class="projects__title">
          {project.url ? (
            <a href={project.url} target="_blank" rel="noopener noreferrer">
              {project.title}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={icons['external-link']} />
              </svg>
            </a>
          ) : (
            project.title
          )}
        </h3>

        <!-- Description -->
        <p class="projects__desc">{project.description}</p>

        <!-- Tags -->
        <div class="projects__tags">
          {project.tags.map((tag) => (
            <span class="projects__tag">{tag}</span>
          ))}
        </div>

        <!-- View button -->
        {project.url && (
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="projects__link">
            View Project
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icons['arrow-right']} />
            </svg>
          </a>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .projects__card {
    position: relative;
    padding: 32px 24px 24px;
    background: var(--color-card);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius);
    backdrop-filter: blur(10px);
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }
  .projects__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: rgba(139, 92, 246, 0.15);
  }

  .projects__bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--gradient-primary);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .projects__card:hover .projects__bar { opacity: 1; }

  .projects__number {
    position: absolute;
    top: 8px;
    right: 16px;
    font-size: 3rem;
    font-weight: 900;
    font-family: var(--font-mono);
    opacity: 0.08;
    pointer-events: none;
    line-height: 1;
  }

  .projects__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .projects__title a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
  }
  .projects__title a:hover { color: var(--color-primary); }
  .projects__title svg { min-width: 16px; }

  .projects__desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .projects__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }
  .projects__tag {
    padding: 3px 10px;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.12);
    border-radius: 100px;
    font-size: 0.72rem;
    color: var(--color-primary);
    font-weight: 500;
  }

  .projects__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: gap 0.2s;
  }
  .projects__link:hover { gap: 10px; }

  :global(html[data-theme='light']) .projects__tag {
    background: rgba(37, 99, 235, 0.06);
    border-color: rgba(37, 99, 235, 0.1);
  }

  @media (max-width: 768px) {
    .projects__grid { grid-template-columns: 1fr; }
  }
</style>
